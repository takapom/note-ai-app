{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "apps/**/*.ts",
    "contexts/**/*.ts"
  ]
}
